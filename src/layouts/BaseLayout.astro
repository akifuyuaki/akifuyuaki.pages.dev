---
import { ClientRouter } from 'astro:transitions';

import '@/assets/css/style.css';

const { title } = Astro.props;
---

<html lang="ja">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <ClientRouter />
        <title>{title} | 秋冬秋の記憶域</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
        <link href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400&text=秋冬秋の記憶域&display=swap" rel="stylesheet">
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    </head>
    <body>
        <header id="site-header">
            <p class="site-title"><a href="/">秋冬秋の記憶域</a></p>
        </header>
        <slot />
        <footer id="site-footer">
            <p>&copy; 2026 秋冬秋の記憶域</p>
        </footer>
        <script>
            document.addEventListener("astro:page-load", () => {
                const moreLinks = document.querySelectorAll(".more-links");
                moreLinks.forEach((btn) => {
                    btn.addEventListener("click", function (e) {
                        const target = e.currentTarget as HTMLElement;
                        const wrapper = target.previousElementSibling as HTMLElement;

                        const isOpen = wrapper.classList.toggle("is-open");
                        target.classList.toggle("is-active");

                        target.textContent = isOpen ? "閉じる" : "もっと見る";
                    });
                });
            });
        </script>
    </body>
</html>